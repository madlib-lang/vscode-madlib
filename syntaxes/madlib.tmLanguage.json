{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Madlib",
  "scopeName": "source.mad",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#preprocessor" },
    { "include": "#jscode" },
    { "include": "#keywords" },
    { "include": "#crash-placeholder" },
    { "include": "#extern" },
    { "include": "#derive" },
    { "include": "#test-fn" },
    { "include": "#interface" },
    { "include": "#imports" },
    { "include": "#types" },
    { "include": "#tuples" },
    { "include": "#operators" },
    { "include": "#constants" },
    { "include": "#function-defs" },
    { "include": "#function-calls" },
    { "include": "#where" },
    { "include": "#access" },
    { "include": "#jsx" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.madlib",
          "match": "//.*$"
        },
        {
          "name": "comment.block.madlib",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "match": "@\\w+", "name": "storage.type.class.jsdoc" }
          ]
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.madlib",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.madlib", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.madlib",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.madlib", "match": "\\\\." }
          ]
        },
        {
          "name": "string.template.madlib",
          "begin": "`",
          "end": "`",
          "patterns": [
            { "include": "#template-interpolation" },
            { "name": "constant.character.escape.madlib", "match": "\\\\." }
          ]
        }
      ]
    },

    "template-interpolation": {
      "patterns": [
        {
          "name": "meta.template.expression.madlib",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.madlib" } },
          "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.madlib" } },
          "patterns": [{ "include": "source.mad" }]
        }
      ]
    },

    "preprocessor": {
      "patterns": [
        {
          "match": "#(iftarget|elseif|endif)\\b(\\s+\\w+)?",
          "captures": {
            "1": { "name": "keyword.preprocessor.madlib" },
            "2": { "name": "constant.other.madlib" }
          }
        }
      ]
    },

    "crash-placeholder": {
      "patterns": [
        {
          "match": "\\?\\?\\?",
          "name": "invalid.illegal.crash-placeholder.madlib"
        }
      ]
    },

    "extern": {
      "patterns": [
        {
          "match": "\\bextern\\b",
          "name": "keyword.other.extern.madlib"
        }
      ]
    },

    "derive": {
      "patterns": [
        {
          "match": "\\b(derive)\\s+([A-Z][a-zA-Z0-9]*)",
          "captures": {
            "1": { "name": "keyword.other.derive.madlib" },
            "2": { "name": "storage.type.madlib" }
          }
        }
      ]
    },

    "test-fn": {
      "patterns": [
        {
          "match": "\\b(test)(?=\\s*\\()",
          "captures": {
            "1": { "name": "keyword.other.test.madlib" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.madlib",
          "match": "\\b(if|else|where|import|type|alias|export|from|return|instance|do)\\b"
        }
      ]
    },

    "imports": {
      "patterns": [
        {
          "comment": "import type { Foo } from 'Module'",
          "match": "\\b(import)\\s+(type)\\s+\\{([^}]*)\\}\\s+(from)\\s+(\"[^\"]*\"|'[^']*')",
          "captures": {
            "1": { "name": "keyword.control.madlib" },
            "2": { "name": "keyword.control.madlib" },
            "3": {
              "patterns": [
                { "match": "\\b[A-Z][a-zA-Z0-9]*\\b", "name": "storage.type.madlib" },
                { "match": "\\b[a-z][a-zA-Z0-9]*\\b", "name": "entity.name.function.madlib" }
              ]
            },
            "4": { "name": "keyword.control.madlib" },
            "5": { "name": "string.quoted.madlib" }
          }
        },
        {
          "comment": "import { Foo, bar } from 'Module'",
          "match": "\\b(import)\\s+\\{([^}]*)\\}\\s+(from)\\s+(\"[^\"]*\"|'[^']*')",
          "captures": {
            "1": { "name": "keyword.control.madlib" },
            "2": {
              "patterns": [
                { "match": "\\b[A-Z][a-zA-Z0-9]*\\b", "name": "storage.type.madlib" },
                { "match": "\\b[a-z][a-zA-Z0-9]*\\b", "name": "entity.name.function.madlib" }
              ]
            },
            "3": { "name": "keyword.control.madlib" },
            "4": { "name": "string.quoted.madlib" }
          }
        },
        {
          "comment": "import Module from 'path'",
          "match": "\\b(import)\\s+([A-Z][a-zA-Z0-9]*)\\s+(from)\\s+(\"[^\"]*\"|'[^']*')",
          "captures": {
            "1": { "name": "keyword.control.madlib" },
            "2": { "name": "entity.name.namespace.madlib" },
            "3": { "name": "keyword.control.madlib" },
            "4": { "name": "string.quoted.madlib" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        { "match": "<-", "name": "keyword.operator.bind.madlib" },
        { "match": ":=", "name": "keyword.operator.assignment.mutation.madlib" },
        { "match": "\\+\\+", "name": "keyword.operator.concatenation.madlib" },
        { "match": ">>>", "name": "keyword.operator.bitwise.madlib" },
        { "match": ">>", "name": "keyword.operator.bitwise.madlib" },
        { "match": "<<", "name": "keyword.operator.bitwise.madlib" },
        { "match": "&&", "name": "keyword.operator.logical.madlib" },
        { "match": "\\|\\|", "name": "keyword.operator.logical.madlib" },
        { "match": "\\|>", "name": "keyword.operator.pipe.madlib" },
        { "match": "->", "name": "keyword.operator.arrow.madlib" },
        { "match": "=>", "name": "keyword.operator.arrow.madlib" },
        { "match": "::", "name": "keyword.operator.double-colon.madlib" },
        { "match": ">=|<=|==|!=", "name": "keyword.operator.comparison.madlib" },
        { "match": "(?<![=!<>])=(?![>=])", "name": "keyword.operator.assignment.madlib" },
        { "match": "\\.\\.\\.", "name": "keyword.operator.spread.madlib" },
        { "match": "\\^", "name": "keyword.operator.bitwise.madlib" },
        { "match": "(?<![a-zA-Z0-9_])&(?!&)", "name": "keyword.operator.bitwise.madlib" },
        { "match": "~", "name": "keyword.operator.bitwise.madlib" },
        { "match": "(?<![a-zA-Z0-9_])!(?!=)", "name": "keyword.operator.logical.madlib" },
        { "match": "\\+(?!\\+)", "name": "keyword.operator.arithmetic.madlib" },
        { "match": "(?<![a-zA-Z0-9_])-(?![>])", "name": "keyword.operator.arithmetic.madlib" },
        { "match": "\\*", "name": "keyword.operator.arithmetic.madlib" },
        { "match": "/(?!/)", "name": "keyword.operator.arithmetic.madlib" },
        { "match": "%", "name": "keyword.operator.arithmetic.madlib" },
        { "match": "(?<![a-zA-Z0-9_<])>(?![>=])", "name": "keyword.operator.comparison.madlib" },
        { "match": "(?<![a-zA-Z0-9_])\\$(?![{a-zA-Z0-9_])", "name": "keyword.operator.placeholder.madlib" },
        { "match": "\\?", "name": "keyword.operator.ternary.madlib" },
        { "match": "(?<![=!<>]):", "name": "keyword.operator.colon.madlib" }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.madlib",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.numeric.hex.madlib",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.madlib",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.decimal.madlib",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },

    "tuples": {
      "patterns": [
        {
          "name": "meta.tuple.madlib",
          "begin": "#\\[",
          "end": "\\]",
          "beginCaptures": { "0": { "name": "punctuation.definition.tuple.begin.madlib" } },
          "endCaptures": { "0": { "name": "punctuation.definition.tuple.end.madlib" } },
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#constants" },
            { "include": "#operators" },
            { "include": "#function-calls" },
            { "include": "#tuples" },
            { "include": "#access" },
            { "include": "#types" }
          ]
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "comment": "type/alias declaration: type Foo = ... or alias Foo = ...",
          "match": "\\b(type|alias)\\s+([A-Z][a-zA-Z0-9]*)([^=]*)(=)",
          "captures": {
            "1": { "name": "keyword.control.madlib" },
            "2": { "name": "storage.type.madlib" },
            "3": {
              "patterns": [
                { "match": "\\b[a-z][a-zA-Z0-9]*\\b", "name": "variable.parameter.madlib" }
              ]
            },
            "4": { "name": "keyword.operator.assignment.madlib" }
          }
        },
        {
          "comment": "Union type variants starting with | Constructor",
          "match": "(?<=\\|)\\s*([A-Z][a-zA-Z0-9]*)",
          "captures": {
            "1": { "name": "entity.name.type.variant.madlib" }
          }
        },
        {
          "comment": "Type constructor (PascalCase identifier)",
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\b",
          "captures": {
            "1": { "name": "storage.type.madlib" }
          }
        }
      ]
    },

    "function-defs": {
      "patterns": [
        {
          "comment": "Type annotation: name :: Type -> Type",
          "match": "^([a-z_][a-zA-Z0-9_]*)\\s*(::)(.*)",
          "captures": {
            "1": { "name": "entity.name.function.madlib" },
            "2": { "name": "keyword.operator.double-colon.madlib" },
            "3": {
              "patterns": [
                { "include": "#types" },
                { "match": "->", "name": "keyword.operator.arrow.madlib" },
                { "match": "=>", "name": "keyword.operator.constraint.madlib" },
                { "match": "\\b[a-z][a-zA-Z0-9]*\\b", "name": "variable.parameter.madlib" }
              ]
            }
          },
          "name": "meta.function.type-annotation.madlib"
        },
        {
          "comment": "Named function definition: name = (params) =>",
          "match": "^([a-z_][a-zA-Z0-9_]*)\\s*=\\s*(?=\\(|where)",
          "captures": {
            "1": { "name": "entity.name.function.madlib" }
          }
        },
        {
          "comment": "Lambda parameters: (a, b) =>",
          "match": "\\(([a-zA-Z0-9_, ]*)\\)\\s*(=>)",
          "captures": {
            "1": {
              "name": "variable.parameter.madlib",
              "patterns": [
                { "match": ",", "name": "punctuation.separator.madlib" }
              ]
            },
            "2": { "name": "keyword.operator.arrow.madlib" }
          }
        }
      ]
    },

    "function-calls": {
      "patterns": [
        {
          "comment": "Module.function( call",
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\.(([a-z][a-zA-Z0-9_]*)(?=\\())",
          "captures": {
            "1": { "name": "entity.name.namespace.madlib" },
            "2": { "name": "entity.name.function.madlib" }
          }
        },
        {
          "comment": "lowercase function call: foo(",
          "match": "\\b([a-z][a-zA-Z0-9_]*)(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.madlib" }
          }
        }
      ]
    },

    "where": {
      "patterns": [
        {
          "comment": "where(...) { pattern matching with scrutinee",
          "match": "\\b(where)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.control.madlib" }
          }
        },
        {
          "comment": "where { pattern matching block",
          "match": "\\b(where)\\s*(?=\\{)",
          "captures": {
            "1": { "name": "keyword.control.madlib" }
          }
        },
        {
          "comment": "Pattern match arm: Constructor(...) =>",
          "match": "\\b([A-Z][a-zA-Z0-9]*)(?=\\s*[({\\[]|\\s+=>)",
          "captures": {
            "1": { "name": "entity.name.type.variant.madlib" }
          }
        },
        {
          "comment": "Wildcard pattern arm",
          "match": "(?<=^|\\s)(_)(?=\\s*=>)",
          "captures": {
            "1": { "name": "variable.language.wildcard.madlib" }
          }
        }
      ]
    },

    "access": {
      "patterns": [
        {
          "comment": "Module.Member access (PascalCase.PascalCase)",
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\.(([A-Z][a-zA-Z0-9]*))",
          "captures": {
            "1": { "name": "entity.name.namespace.madlib" },
            "2": { "name": "storage.type.madlib" }
          }
        },
        {
          "comment": "Module.member access (PascalCase.camelCase)",
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\.([a-z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.namespace.madlib" },
            "2": { "name": "variable.other.property.madlib" }
          }
        },
        {
          "comment": "Record field accessor .fieldName used as function",
          "match": "(?<![a-zA-Z0-9_])\\.([a-z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.property.madlib" }
          }
        }
      ]
    },

    "interface": {
      "patterns": [
        {
          "comment": "interface/instance with constraint: interface (Foo a) => Bar a {",
          "match": "\\b(interface|instance)\\b(.+?)(=>)(.+?)(?=\\{|$)",
          "captures": {
            "1": { "name": "keyword.control.madlib" },
            "2": {
              "patterns": [
                { "match": "\\b[A-Z][a-zA-Z0-9]*\\b", "name": "storage.type.madlib" },
                { "match": "\\b[a-z][a-zA-Z0-9]*\\b", "name": "variable.parameter.madlib" }
              ]
            },
            "3": { "name": "keyword.operator.constraint.madlib" },
            "4": {
              "patterns": [
                { "match": "\\b[A-Z][a-zA-Z0-9]*\\b", "name": "storage.type.madlib" },
                { "match": "\\b[a-z][a-zA-Z0-9]*\\b", "name": "variable.parameter.madlib" }
              ]
            }
          }
        },
        {
          "comment": "interface/instance without constraint: instance Functor List {",
          "match": "\\b(interface|instance)\\b(.+?)(?=\\{|$)",
          "captures": {
            "1": { "name": "keyword.control.madlib" },
            "2": {
              "patterns": [
                { "match": "\\b[A-Z][a-zA-Z0-9]*\\b", "name": "storage.type.madlib" },
                { "match": "\\b[a-z][a-zA-Z0-9]*\\b", "name": "variable.parameter.madlib" }
              ]
            }
          }
        }
      ]
    },

    "jscode": {
      "name": "meta.embedded.js-block.madlib",
      "begin": "#-(?!-#)",
      "end": "-#",
      "beginCaptures": { "0": { "name": "punctuation.definition.jscode.begin.madlib" } },
      "endCaptures": { "0": { "name": "punctuation.definition.jscode.end.madlib" } },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [{ "include": "source.js" }]
    },

    "jsx": {
      "comment": "Avoid < operator expressions as best we can",
      "patterns": [
        {
          "begin": "(?<=\\(|{|\\[|&&|\\|\\||\\?|:|=|=>|\\Wreturn|^return|^)\\s*+(?=<([^,]|[ ]*|\\{.*\\})+$|<\\s*>)",
          "end": "(?=.)",
          "applyEndPatternLast": 1,
          "patterns": [
            { "include": "#jsx-tag-element-name" }
          ]
        }
      ]
    },

    "jsx-tag-element-name": {
      "patterns": [
        {
          "comment": "JSX Fragment <>...</>",
          "name": "meta.tag.jsx",
          "begin": "\\s*(<)\\s*(?=>)",
          "end": "(?<=</)(>)",
          "beginCaptures": { "1": { "name": "punctuation.definition.tag.jsx" } },
          "endCaptures": { "1": { "name": "punctuation.definition.tag.jsx" } },
          "patterns": [{ "include": "#jsx-tag-termination" }]
        },
        {
          "name": "meta.tag.jsx",
          "begin": "\\s*(<)((\\p{Ll}[\\p{Ll}0-9]*)|((?:[$_\\p{L}\\p{Nl}][$_\\p{L}\\p{Mn}\\p{Mc}\\p{Nd}\\p{Nl}\\p{Pc}-]*?:)?+(?:[$_\\p{L}\\p{Nl}](?:[$_\\p{L}\\p{Mn}\\p{Mc}\\p{Nd}\\p{Nl}\\p{Pc}\\.-](?<!\\.\\.))*+)+))(?=[ />\\s])(?![:])(?<!\\.|:)",
          "end": "\\s*(?<=</)((\\4)|\\2)(>)|(/>)|((?<=</)[\\S ]*?)>",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.jsx" },
            "2": { "name": "entity.name.tag.open.jsx" },
            "4": { "name": "support.class.component.open.jsx" }
          },
          "endCaptures": {
            "1": { "name": "entity.name.tag.close.jsx" },
            "2": { "name": "support.class.component.close.jsx" },
            "3": { "name": "punctuation.definition.tag.jsx" },
            "4": { "name": "punctuation.definition.tag.jsx" },
            "5": { "name": "invalid.illegal.termination.jsx" }
          },
          "patterns": [
            { "include": "#jsx-tag-termination" },
            { "include": "#jsx-tag-attributes" }
          ]
        }
      ]
    },

    "jsx-tag-termination": {
      "patterns": [
        {
          "contentName": "meta.jsx.children",
          "begin": "(>)",
          "end": "(</)",
          "beginCaptures": { "1": { "name": "punctuation.definition.tag.jsx" } },
          "endCaptures": { "1": { "name": "punctuation.definition.tag.jsx" } },
          "patterns": [
            { "include": "#jsx-evaluated-code" },
            { "include": "#jsx-entities" },
            { "include": "#jsx-tag-element-name" }
          ]
        }
      ]
    },

    "jsx-tag-attributes": {
      "patterns": [
        { "include": "#jsx-attribute-name" },
        { "include": "#jsx-assignment" },
        { "include": "#jsx-string-double-quoted" },
        { "include": "#jsx-string-single-quoted" },
        { "include": "#jsx-evaluated-code" },
        { "include": "#jsx-tag-element-name" },
        { "include": "#comments" }
      ]
    },

    "jsx-spread-attribute": {
      "patterns": [
        { "match": "(?<!\\.)\\.\\.\\.", "name": "keyword.operator.spread.jsx" }
      ]
    },

    "jsx-attribute-name": {
      "patterns": [
        {
          "match": "(?<!\\S)([$_\\p{L}](?:[$.\\p{L}\\p{Mn}\\p{Mc}\\p{Nd}\\p{Nl}\\p{Pc}-](?<!\\.\\.))*+)(?<!\\.)(?=//|/\\*|=|\\s|>|/>)",
          "captures": { "0": { "name": "entity.other.attribute-name.jsx" } }
        }
      ]
    },

    "jsx-assignment": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.jsx",
          "match": "=(?=\\s*(?:'|\"|{|/\\*|<|//|\\n))"
        }
      ]
    },

    "jsx-string-double-quoted": {
      "name": "string.quoted.double.jsx",
      "begin": "\"",
      "end": "\"(?<!\\\\\")",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.jsx" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.jsx" } },
      "patterns": [{ "include": "#jsx-entities" }]
    },

    "jsx-string-single-quoted": {
      "name": "string.quoted.single.jsx",
      "begin": "'",
      "end": "'(?<!\\\\')",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.jsx" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.jsx" } },
      "patterns": [{ "include": "#jsx-entities" }]
    },

    "jsx-evaluated-code": {
      "patterns": [
        {
          "name": "meta.embedded.expression.jsx",
          "contentName": "source.mad",
          "begin": "{",
          "end": "}",
          "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.jsx" } },
          "endCaptures": { "0": { "name": "punctuation.section.embedded.end.jsx" } },
          "patterns": [
            { "include": "source.mad" },
            { "include": "#jsx-string-double-quoted" },
            { "include": "#jsx-string-single-quoted" },
            { "include": "#jsx-spread-attribute" }
          ]
        }
      ]
    },

    "jsx-entities": {
      "patterns": [
        {
          "match": "(&)([a-zA-Z0-9]+|#[0-9]+|#x[0-9a-fA-F]+)(;)",
          "captures": {
            "0": { "name": "constant.character.entity.jsx" },
            "1": { "name": "punctuation.definition.entity.jsx" },
            "2": { "name": "entity.name.tag.html.jsx" },
            "3": { "name": "punctuation.definition.entity.jsx" }
          }
        },
        { "match": "&\\s*+;", "name": "invalid.illegal.bad-ampersand.jsx" }
      ]
    }
  }
}
