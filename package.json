{
  "name": "madlib",
  "displayName": "Madlib",
  "description": "Language support for the Madlib programming language",
  "version": "0.8.0",
  "main": "client/src/index.js",
  "activationEvents": [
    "onLanguage:madlib",
    "onCommand:madlib.restartLanguageServer",
    "onCommand:madlib.showOutputChannel"
  ],
  "publisher": "madlib-lang",
  "repository": {
    "url": "https://github.com/madlib-lang/vscode-madlib"
  },
  "engines": {
    "vscode": "^1.51.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "commands": [
      {
        "command": "madlib.restartLanguageServer",
        "title": "Madlib: Restart Language Server"
      },
      {
        "command": "madlib.showOutputChannel",
        "title": "Madlib: Show Language Server Output"
      }
    ],
    "configuration": {
      "title": "Madlib",
      "properties": {
        "madlib.server.path": {
          "type": "string",
          "default": "madlib",
          "description": "Path to the madlib binary. Defaults to 'madlib' on PATH.",
          "scope": "machine-overridable"
        },
        "madlib.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace level for Madlib language server communication. Useful for debugging.",
          "scope": "window"
        },
        "madlib.format.onSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format Madlib files on save.",
          "scope": "resource"
        }
      }
    },
    "languages": [
      {
        "id": "madlib",
        "aliases": [
          "Madlib",
          "madlib"
        ],
        "extensions": [
          ".mad"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "madlib",
        "scopeName": "source.mad",
        "path": "./syntaxes/madlib.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript",
          "meta.embedded.block.javascript": "javascript",
          "meta.embedded.js-block.madlib": "javascript"
        }
      }
    ],
    "snippets": [
      {
        "language": "madlib",
        "path": "./snippets/madlib.json"
      }
    ]
  }
}
